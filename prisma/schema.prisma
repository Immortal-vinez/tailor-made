// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  phone     String?
  // "customer" | "admin" — admin is set via env vars, not DB rows
  role      String   @default("customer")
  resetTokens PasswordResetToken[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Customer enquiry captured from the storefront (WhatsApp-intent)
model Request {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String
  productId     String?
  productName   String?
  message       String?
  // pending | replied | closed
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Product stored locally (used when Google Sheets is not configured)
model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  imageUrl    String   @default("")
  sizes       String   @default("")
  colors      String   @default("")
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([featured])
  @@index([createdAt])
  @@index([category, featured, createdAt])
}

// Order manually logged or captured from the storefront
model Order {
  id            String   @id @default(cuid())
  customerName  String
  customerPhone String
  customerEmail String?
  // JSON-encoded array of {productId, productName, price, qty, size?, color?}
  items         String   @default("[]")
  totalAmount   Float    @default(0)
  // pending | confirmed | shipped | delivered | cancelled
  status        String   @default("pending")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}